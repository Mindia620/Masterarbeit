@article{choudharyImpactCloudComputing2013a,
  title = {The {{Impact}} of {{Cloud Computing}}: {{Should}} the {{IT Department Be Organized}} as a {{Cost Center}} or a {{Profit Center}}?},
  shorttitle = {The {{Impact}} of {{Cloud Computing}}},
  author = {Choudhary, Vidyanand and Vithayathil, Joseph},
  year = {2013},
  month = oct,
  journal = {Journal of Management Information Systems},
  volume = {30},
  number = {2},
  pages = {67--100},
  publisher = {Routledge},
  issn = {0742-1222},
  doi = {10.2753/MIS0742-1222300203},
  urldate = {2024-10-18},
  abstract = {How does the adoption of cloud computing by a firm affect the organizational structure of its information technology (IT) department? To analyze this question, we consider an IT department that procures IT services from a cloud computing vendor and enhances these services for consuming units within the firm. Our model incorporates the competitive environment faced by the cloud vendor, which affects the price of the cloud vendor. We find that when the cloud vendor faces intense competition, the cost-center organizational model is preferred over the profit-center model. Infrastructure services such as basic storage, e-mail, and raw computing face intense competition, and our results suggest that such services be offered as a free corporate resource under the cost-center organizational structure. When the cloud vendor has pricing power, a profit-center organizational structure is likely to be preferred. Our results suggest that highly differentiated services such as cloud-based enterprise-wide enterprise resource planning or business intelligence be offered under the profit-center structure. Finally, the profit-center structure provides greater internal quality enhancement to cloud-based IT services than the cost center.},
  keywords = {chargeback,cloud,cloud computing,cost center,IaaS,IT governance,PaaS,profit center,SaaS,supply chain}
}

@misc{COBITAPO0604Model2024,
  title = {{{COBIT APO06}}.04 - {{Model And Allocate Costs}}},
  year = {2024},
  month = may,
  journal = {ITSM Docs - ITSM Documents \& Templates},
  urldate = {2025-03-02},
  abstract = {Introduction COBIT APO06.04 focuses on the critical process of modeling and allocating organizational costs. This process is essential for effective financial management and ensuring that resources are allocated optimally. By implementing the guidelines outlined in COBIT APO06.04, organizations can streamline their cost allocation processes, improve financial transparency, and make well-informed decisions regarding resource allocation. Strategic Cost Allocation Strategies For Optimizing Budget Management In COBIT APO06.04 1. Align cost allocation with organizational goals: One of the first steps in implementing cost allocation strategies is to align them with the organization's overall goals and objectives. By understanding the company's strategic priorities, departments can allocate costs in a way that supports those goals and helps drive success.2. Implement activity-based costing: Activity-based costing is a method of cost allocation that assigns costs based on the activities that drive them. By identifying key activities within each department or project, organizations can better allocate costs and understand where resources are being spent most effectively.3. Use cost drivers to allocate expenses: Cost drivers are factors that directly influence the costs of a particular activity or project. By identifying these drivers, organizations can allocate expenses based on the factors that actually impact costs rather than simply dividing them evenly across departments.4. Regularly review and adjust cost allocation methods: Cost allocation strategies should not be set in stone. It's important for organizations to regularly review their methods and adjust them as needed to ensure that costs are being allocated effectively and efficiently.5. Utilize technology for cost allocation: Technology can play a crucial role in optimizing cost allocation strategies. By implementing software tools that automate the process of allocating costs and tracking expenses, organizations can improve accuracy and efficiency in their budget management.6. Communicate cost allocation strategies transparently: Transparency is key when implementing cost allocation strategies. By clearly communicating how costs are allocated and why, organizations can ensure that all stakeholders understand the rationale behind budget decisions. Importance Of Effective Cost Modeling And Allocation In COBIT APO06.04 COBIT APO06.04 is a framework that provides guidelines for effective cost modeling and allocation, ensuring that resources are utilized efficiently and effectively. Effective cost modeling involves estimating the costs of a particular project or operation, considering all relevant factors such as labor, materials, overheads, and other expenses. By accurately predicting costs, organizations can make informed decisions regarding budgeting, pricing, and resource allocation. This helps ensure that projects are completed within budget constraints and allows for better financial planning and management.Furthermore, cost allocation is the practice of distributing costs across different departments, products, or services based on their usage or benefit. This is crucial for measuring the profitability of various segments within an organization and identifying areas where costs can be reduced or optimized. By allocating costs accurately, organizations can make informed decisions on pricing strategies, product profitability, and resource allocation, ultimately leading to improved financial performance. Impact Of Efficient Cost Allocation On Business Performance In COBIT APO06.04 Cost allocation plays a crucial role in the success of any business organization. The COBIT framework, specifically the APO06.04 process, focuses on the efficient allocation of costs to various activities and resources within an organization. This process helps optimize resource use and improve overall business performance.Efficient cost allocation ensures that resources are allocated to activities that provide the most value to the organization. By accurately tracking and allocating costs, businesses can make informed decisions about resource allocation, budgeting, and performance evaluation. This enables organizations to identify areas of inefficiency and take corrective actions to improve overall performance.One of the key benefits of efficient cost allocation is improved cost management. By accurately allocating costs to specific activities, departments, or products, organizations can better understand their cost structure and identify opportunities for cost savings. This allows businesses to optimize their spending and maximize the return on investment.Furthermore, efficient cost allocation helps improve the organization's transparency and accountability. By accurately tracking costs and allocating them to specific activities, businesses can hold individuals and departments accountable for their spending. This promotes better decision-making and ensures that resources are used in the most effective and efficient manner. Tools And Resources For Effective Cost Modeling And Allocation In Budget Management Of COBIT APO06.04 1. Activity-Based Costing (ABC) Systems: ABC systems are widely used in cost modeling to allocate indirect costs to products and services based on the activities that consume resources. By implementing an ABC system, organizations can better understand the true cost of their products and services, enabling them to make more accurate pricing decisions and identify opportunities for cost reduction.2. Cost Estimation Tools: Cost estimation tools are essential for predicting the costs associated with projects or activities. These tools use historical data, industry benchmarks, and other factors to estimate the resources and expenses required for a specific task or project. Using cost estimation tools, organizations can create more realistic budgets and allocate resources effectively.3. Cost Allocation Software: Cost allocation software streamlines the process of assigning costs to various cost centers or activities within an organization. This software allows organizations to track expenses accurately and allocate costs based on predetermined allocation methods. By using cost allocation software, organizations can ensure that costs are distributed fairly and accurately across different departments or projects.4. Decision Support Systems (DSS): Decision support systems are tools that help organizations make informed decisions by analyzing data and providing insights into cost-effective strategies. DSS can assist organizations in identifying cost-saving opportunities, optimizing resource allocation, and improving overall cost management practices. By leveraging DSS, organizations can make data-driven decisions that lead to cost savings and improved financial performance.5. Cost Management Dashboards: Cost management dashboards provide real-time visibility into an organization's costs, budgets, and spending trends. These dashboards allow stakeholders to monitor key cost metrics, track performance against targets, and identify areas for improvement. By using cost management dashboards, organizations can proactively manage costs, address deviations from budgeted expenses, and make timely adjustments to their cost allocation~strategies. Conclusion The COBIT APO06.04 framework provides a comprehensive approach to model and allocate costs within an organization. By implementing this standard, businesses can effectively manage their financial resources and optimize their cost structures. Embracing the COBIT APO06.04 guidelines is essential for achieving financial transparency and accountability.},
  howpublished = {https://www.itsm-docs.com/en-de/blogs/cobit-framework/cobit-apo06-04-model-and-allocate-costs},
  langid = {english},
  file = {C:\Users\mindi\Zotero\storage\N3NY6GHP\cobit-apo06-04-model-and-allocate-costs.html}
}

