  keywords = {⛔ No DOI found},
  file = {C:\Users\mindi\Zotero\storage\AK7ZDE3X\Kim et al. - 2025 - AI Governance in the Context of the EU AI Act A B.pdf}
}

@article{koniakouRushEthicsRace2023,
